---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Justification">
    <section class="space-y-10">
        <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-indigo-600 mb-3">
                Rand Water Project
            </p>
            <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 mb-4">
                Justification
            </h1>
            <p class="text-lg text-slate-600">
                Using plastic or composite materials discourages theft because these parts have low resale
                and recyclability value. Thieves are less motivated to steal components that do not yield
                meaningful profit, which reduces vandalism and protects water meter infrastructure.
            </p>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Main Justification Table</h2>

            <div class="overflow-x-auto">
                <table class="w-full border-collapse text-left">
                    <thead>
                    <tr class="bg-slate-50 text-slate-700">
                        <th class="px-4 py-3 font-semibold border-b border-slate-200">Criteria</th>
                        <th class="px-4 py-3 font-semibold border-b border-slate-200">Old Materials (Metal)</th>
                        <th class="px-4 py-3 font-semibold border-b border-slate-200">Modern Materials (Plastic/Composite)</th>
                    </tr>
                    </thead>
                    <tbody class="text-slate-700">
                    <tr>
                        <td class="px-4 py-3 border-b border-slate-200">Failure risk</td>
                        <td class="px-4 py-3 border-b border-slate-200">High</td>
                        <td class="px-4 py-3 border-b border-slate-200">Low</td>
                    </tr>
                    <tr>
                        <td class="px-4 py-3 border-b border-slate-200">Corrosion</td>
                        <td class="px-4 py-3 border-b border-slate-200">Severe issue</td>
                        <td class="px-4 py-3 border-b border-slate-200">Resistant</td>
                    </tr>
                    <tr>
                        <td class="px-4 py-3 border-b border-slate-200">Maintenance</td>
                        <td class="px-4 py-3 border-b border-slate-200">Frequent</td>
                        <td class="px-4 py-3 border-b border-slate-200">Reduced</td>
                    </tr>
                    <tr>
                        <td class="px-4 py-3">Infrastructure strategy</td>
                        <td class="px-4 py-3">Infrastructure strategy</td>
                        <td class="px-4 py-3">Reactive</td>
                    </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</MainLayout>