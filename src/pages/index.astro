---
import MainLayout from '../layouts/MainLayout.astro';
import { Image } from 'astro:assets';
import productImg from '../assets/product.png';

import member1 from '../assets/member_1.jpeg';
import member2 from '../assets/member_2.jpeg';
import member3 from '../assets/member_3.jpeg';
import member4 from '../assets/member_4.jpeg';

const teamMembers = [
    { name: 'Rapolas Daugelis', role: 'Mechanical Engineer', img: member1 },
    { name: 'Greta Stundžytė', role: 'Economics | Team leader', img: member2 },
    { name: 'Mantė Vėželytė', role: 'Materials Scientist', img: member3 },
    { name: 'Daumantas Baltakis', role: 'Software Engineer', img: member4 }
];
---

<MainLayout title="Last Minuters">
    <section class="relative pt-32 pb-20 overflow-hidden">
        <div class="absolute -top-24 -left-24 w-96 h-96 bg-indigo-200/50 rounded-full mix-blend-multiply filter blur-3xl opacity-70 animate-blob"></div>
        <div class="absolute top-0 -right-24 w-96 h-96 bg-blue-200/50 rounded-full mix-blend-multiply filter blur-3xl opacity-70 animate-blob animation-delay-2000"></div>
        <div class="absolute -bottom-24 left-1/2 w-96 h-96 bg-pink-100/50 rounded-full mix-blend-multiply filter blur-3xl opacity-70 animate-blob animation-delay-4000"></div>

        <div class="relative max-w-5xl mx-auto px-4 text-center">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-50 border border-indigo-100 text-indigo-700 text-xs font-bold uppercase tracking-wider mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
        </span>
        About Our Team
      </span>

            <h1 class="text-5xl md:text-7xl font-black text-slate-900 tracking-tight mb-6">
                The Last Minuters
            </h1>

            <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed mb-10">
                We’re a student team focused on practical, low-cost infrastructure solutions.
                Our 2026 project works with Rand Water to address vandalism affecting water meters.
            </p>
        </div>
    </section>

    <section class="max-w-5xl mx-auto px-4 py-24">
        <div class="grid md:grid-cols-2 gap-16 items-center">
            <div>
                <h2 class="text-3xl font-bold text-slate-900 mb-6 italic">The Challenge</h2>
                <p class="text-lg text-slate-600 mb-6 leading-relaxed">
                    Research conducted into water infrastructure vandalism in South Africa showed that one of the major drivers of such vandalism is illegal scrap metal harvesting. Metal is intrinsically valuable, making infrastructure a prime target for criminals.
                </p>
                <p class="text-lg text-slate-600 mb-6 leading-relaxed">
                    While water providers have been working to reduce the share of metal in heavily stolen parts, not all components have been successfully replaced. Our team identified that the <strong>isolating valves of water metres</strong>—often made of brass—are a critical vulnerability.
                </p>
                <div class="space-y-4">
                    <div class="flex items-start gap-4 p-4 rounded-2xl bg-slate-50 border border-slate-100">
                        <div class="bg-indigo-600 text-white p-2 rounded-lg mt-1">
                            <svg class="w-5 h-5" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        </div>
                        <div>
                            <h4 class="font-bold">Illegal Scrap Harvesting</h4>
                            <p class="text-sm text-slate-500">Brass and metal valves are highly targeted due to their rapid resale value on the black market.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="relative group">
                <div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 to-blue-500 rounded-3xl blur opacity-25 group-hover:opacity-50 transition duration-1000"></div>
                <div class="relative h-80 bg-slate-100 rounded-3xl border border-slate-200 flex items-center justify-center overflow-hidden">
                    <Image src={productImg} alt="Field Research Image" class="w-full h-full object-cover" />
                </div>
            </div>
        </div>
    </section>

    <section class="bg-slate-50 py-24">
        <div class="max-w-5xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold mb-8">Our Solution</h2>
            <p class="text-lg text-slate-600 max-w-4xl mx-auto leading-relaxed mb-6">
                Therefore, we designed an isolating valve to be made entirely out of plastic, replacing the brass and metal valves that are currently used the most. Our design is based on a commonly employed spherical plug or rotary ball mechanism. A perforated ball controls the liquid: when the bore aligns with the pipe, water flows freely; otherwise, it blocks the current.
            </p>
            <p class="text-lg text-slate-600 max-w-4xl mx-auto leading-relaxed mb-12">
                In our design, the ball is fused with a shaft, allowing the user to change water flow with high precision. The valve is angular, possessing a smooth 90-degree bend that helps reduce turbulence. Most crucially, an adjustable threaded plug is included to control the tightness of the ball and easily replace parts. Being 100% plastic, it serves as the perfect deterrent against vandalism in South Africa.
            </p>

            <div class="grid md:grid-cols-3 gap-6 text-left">
                <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                    <h3 class="font-bold text-slate-900 mb-2">100% Plastic Design</h3>
                    <p class="text-sm text-slate-500">Completely eliminates the resale value associated with traditional brass and metal valves, deterring scrap thieves.</p>
                </div>
                <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                    <h3 class="font-bold text-slate-900 mb-2">Angular Ball Mechanism</h3>
                    <p class="text-sm text-slate-500">Features a smooth 90-degree twist fused with a precise shaft to easily control flow while effectively reducing water turbulence.</p>
                </div>
                <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                    <h3 class="font-bold text-slate-900 mb-2">Adjustable & Serviceable</h3>
                    <p class="text-sm text-slate-500">Includes a threaded plug to manually control ball tightness and swap individual internal parts, increasing product longevity.</p>
                </div>
            </div>
        </div>
    </section>
    <section class="bg-slate-50 py-24">
        <div class="max-w-5xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold mb-12">The Minds Behind The Project</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                {teamMembers.map(member => (
                        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex flex-col items-center">
                            <Image
                                    src={member.img}
                                    alt={member.name}
                                    class="w-16 h-16 rounded-full object-cover mx-auto mb-4 border-2 border-slate-100 shadow-sm"
                            />
                            <div class="font-bold text-slate-900">{member.name}</div>
                            <div class="text-xs text-slate-500 uppercase mt-1 tracking-tighter">{member.role}</div>
                        </div>
                ))}
            </div>
        </div>
    </section>

    <footer class="py-20 text-center">
        <p class="text-slate-400 text-sm mb-4">Ready to see the full results?</p>
        <a href="/downloads" class="inline-flex items-center gap-2 text-indigo-600 font-bold hover:underline">
            Access the Download Portal <svg class="w-4 h-4" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
    </footer>
</MainLayout>