            { name: "2.5 End-to-end procurement process", hrs: "120", rate: "8.82", mat: "-", travel: "-", other: "-", total: "1,058.40", comments: "1 Supply Chain Manager" },
            { name: "— 2.5.1 Procurement Preparation", hrs: "40", rate: "8.82", mat: "-", travel: "-", other: "-", total: "352.80", comments: "Sub-task" },
            { name: "— 2.5.2 Supplier tendering & evaluation", hrs: "40", rate: "8.82", mat: "-", travel: "-", other: "-", total: "352.80", comments: "Sub-task" },
