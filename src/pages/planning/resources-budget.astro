---
import MainLayout from '../../layouts/MainLayout.astro';

// Parsed and structured CSV Data
const summary = {
    projectName: "Using cheaper materials (to deal with vandalism)",
    startDate: "Jun 1, 2026",
    endDate: "Dec 1, 2026",
    budget: "29,715.00 €",
    budgetWithRisk: "32,686.50 €",
