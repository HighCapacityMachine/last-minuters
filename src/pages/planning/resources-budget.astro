            { name: "1.2 Schedule & Budget Baseline", hrs: "40", rate: "13.52", mat: "-", travel: "-", other: "-", total: "540.80", comments: "1 Project Manager" },
            { name: "1.3 Stakeholder Communication Plan", hrs: "40", rate: "13.52", mat: "-", travel: "300.00", other: "250.00", total: "1,090.80", comments: "1 Project Manager; Travel: local trips; Other: printing" },
            { name: "1.4 Risk Management Plan", hrs: "40", rate: "13.52", mat: "-", travel: "-", other: "-", total: "540.80", comments: "1 Project Manager" },
        ]
    },
    {
        name: "Phase Two: Planning & Procurement",
        total: "8,334.20 €",
        items: [
            { name: "2.1 Vandalism Report", hrs: "80", rate: "8.91", mat: "-", travel: "150.00", other: "250.00", total: "1,112.80", comments: "1 person from Operations; Travel to sites; Other: printing" },
            { name: "2.2 Material Benchmarking", hrs: "80", rate: "31.88", mat: "1,725.00", travel: "-", other: "-", total: "4,275.40", comments: "2 Materials Scientists; Material: samples for testing" },
            { name: "2.3 Cost Savings Estimation", hrs: "40", rate: "13.52", mat: "-", travel: "-", other: "-", total: "540.80", comments: "1 Project Manager" },
