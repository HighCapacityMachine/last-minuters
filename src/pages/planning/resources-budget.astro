        ]
    },
    {
        name: "Phase Three: Execution",
        total: "10,965.60 €",
        items: [
            { name: "3.1 Conceptual CAD Models", hrs: "80", rate: "16.75", mat: "4,152.00", travel: "-", other: "-", total: "5,492.00", comments: "1 Mech Engineer; Material: SolidWorks yearly sub" },
            { name: "— 3.1.1 Design the device", hrs: "50", rate: "16.75", mat: "-", travel: "-", other: "-", total: "837.50", comments: "Sub-task" },
            { name: "— 3.1.2 Create the CAD model", hrs: "30", rate: "16.75", mat: "-", travel: "-", other: "-", total: "502.50", comments: "Sub-task" },
            { name: "3.2 Digital Testing", hrs: "80", rate: "16.75", mat: "-", travel: "-", other: "-", total: "1,340.00", comments: "1 Mech Engineer" },
            { name: "— 3.2.1 Verify structural strength", hrs: "40", rate: "16.75", mat: "-", travel: "-", other: "-", total: "670.00", comments: "Sub-task" },
            { name: "— 3.2.2 Verify proper fluid flow", hrs: "40", rate: "16.75", mat: "-", travel: "-", other: "-", total: "670.00", comments: "Sub-task" },
            { name: "3.3 Prototype Verification", hrs: "80", rate: "16.75", mat: "600.00", travel: "-", other: "-", total: "1,940.00", comments: "1 Mech Engineer; Material: prototype testing materials" },
            { name: "3.4 Final Technical Drawings", hrs: "80", rate: "27.42", mat: "-", travel: "-", other: "-", total: "2,193.60", comments: "1 Senior Mech Engineer" },
        ]
    },
    {
        name: "Phase Four: Control",
        total: "3,972.00 €",
        items: [
            { name: "4.1 Testing Under Real-Life Conditions", hrs: "120", rate: "33.50", mat: "-", travel: "-", other: "-", total: "1,986.00", comments: "2 Mech Engineers" },
            { name: "— 4.1.1 Controlled env testing", hrs: "60", rate: "33.50", mat: "-", travel: "-", other: "-", total: "2,010.00", comments: "Sub-task" },
            { name: "— 4.1.2 In location testing", hrs: "60", rate: "33.50", mat: "-", travel: "-", other: "-", total: "2,010.00", comments: "Sub-task" },
            { name: "4.2 Monitoring Vandalism of New Product", hrs: "120", rate: "16.55", mat: "-", travel: "-", other: "-", total: "1,986.00", comments: "1 QA Engineer" },
        ]
    },
    {
        name: "Phase Five: Closeout",
        total: "3,730.00 €",
        items: [
            { name: "5.1 Final Prototype Delivery", hrs: "40", rate: "27.42", mat: "-", travel: "400.00", other: "-", total: "1,496.80", comments: "1 Senior Mech Engineer; Travel: local trips" },
            { name: "5.2 Technical Documentation Package", hrs: "60", rate: "27.42", mat: "-", travel: "-", other: "250.00", total: "1,895.20", comments: "1 Senior Mech Engineer; Other: printing" },
            { name: "5.3 Lessons Learned", hrs: "25", rate: "13.52", mat: "-", travel: "-", other: "-", total: "338.00", comments: "1 Project Manager" },
        ]
    }
];
---

<MainLayout title="Resources & Budget">
    <section class="space-y-10">
        <header class="max-w-4xl">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-indigo-600 mb-3">
                Planning
            </p>
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 mb-4">
                Project Budget
            </h1>
            <p class="text-lg text-slate-600">
                Cost estimation based on labor, material, travel, and operations.
            </p>
        </header>

        <!-- Summary Cards -->
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <p class="text-sm font-semibold text-slate-500 mb-1">Start Date</p>
                <p class="text-xl font-bold text-slate-900">{summary.startDate}</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <p class="text-sm font-semibold text-slate-500 mb-1">End Date</p>
                <p class="text-xl font-bold text-slate-900">{summary.endDate}</p>
            </div>
            <div class="rounded-2xl border border-indigo-200 bg-indigo-50 p-5 shadow-sm">
                <p class="text-sm font-semibold text-indigo-600 mb-1">Base Budget</p>
                <p class="text-xl font-bold text-indigo-900">{summary.budget}</p>
            </div>
            <div class="rounded-2xl border border-rose-200 bg-rose-50 p-5 shadow-sm">
                <p class="text-sm font-semibold text-rose-600 mb-1">With 10% Risk Budget</p>
                <p class="text-xl font-bold text-rose-900">{summary.budgetWithRisk}</p>
            </div>
        </div>

        <!-- Budget Table -->
        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
            <div class="overflow-x-auto min-w-[1000px]">
                <table class="w-full border-collapse text-left text-sm">
                    <thead>
                    <tr class="bg-indigo-50 text-indigo-900 border-b border-slate-200">
                        <th class="px-4 py-3 font-bold w-1/3">Task</th>
                        <th class="px-2 py-3 font-semibold text-right">Hrs</th>
                        <th class="px-2 py-3 font-semibold text-right">Rate (€/h)</th>
                        <th class="px-2 py-3 font-semibold text-right">Material (€)</th>
                        <th class="px-2 py-3 font-semibold text-right">Travel (€)</th>
                        <th class="px-2 py-3 font-semibold text-right">Other (€)</th>
                        <th class="px-3 py-3 font-bold text-right bg-indigo-100">Total Budget</th>
                        <th class="px-4 py-3 font-semibold w-1/3">Comments</th>
                    </tr>
                    </thead>
                    <tbody class="text-slate-700">
                    {phases.map((phase) => (
                            <>
                                <tr class="bg-slate-100/50">
                                    <td class="px-4 py-3 font-bold text-slate-900 border-b border-slate-200">
                                        {phase.name}
                                    </td>
                                    <td class="px-3 py-3 font-bold text-slate-900 text-right border-b border-slate-200">
                                        {phase.total}
                                    </td>
                                    <td class="border-b border-slate-200"></td>
                                </tr>
                                {phase.items.map((row) => (
                                        <tr class="hover:bg-slate-50 border-b border-slate-100 last:border-0 transition-colors">
                                            <td class={`px-4 py-2 ${row.name.startsWith('—') ? 'pl-8 text-slate-500' : 'font-medium'}`}>{row.name}</td>
                                            <td class="px-2 py-2 text-right">{row.hrs}</td>
                                            <td class="px-2 py-2 text-right">{row.rate}</td>
                                            <td class="px-2 py-2 text-right">{row.mat}</td>
                                            <td class="px-2 py-2 text-right">{row.travel}</td>
                                            <td class="px-2 py-2 text-right">{row.other}</td>
                                            <td class="px-3 py-2 text-right font-medium text-slate-900">{row.total} €</td>
                                            <td class="px-4 py-2 text-xs text-slate-500 leading-relaxed">{row.comments}</td>
                                        </tr>
                                ))}
                            </>
                    ))}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</MainLayout>