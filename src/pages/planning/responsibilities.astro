---
import MainLayout from '../../layouts/MainLayout.astro';

const responsibilities = [
    { member: "Project Manager", task: "1.1 Project Charter & Scope analysis", dept: "Management", color: "bg-yellow-100" },
    { member: "Project Manager", task: "1.2 Schedule, Budget Baseline", dept: "Management", color: "bg-yellow-100" },
    { member: "Project Manager", task: "1.3 Stakeholder Communication Plan", dept: "Management", color: "bg-yellow-100" },
    { member: "Project Manager", task: "1.4 Risk Management Plan", dept: "Management", color: "bg-yellow-100" },

    { member: "Team Member of Operations", task: "2.1 Vandalism Report", dept: "Operations Department", color: "bg-red-100" },
    { member: "Materials Scientist", task: "2.2 Material benchmarking", dept: "Scientific Services", color: "bg-purple-100" },
    { member: "Project Manager", task: "2.3 Cost savings estimation", dept: "Management & Finance", color: "bg-yellow-100" },
    { member: "Senior Mechanical Engineer", task: "2.4 Compliance & regulatory analysis", dept: "Engineering Dept & Legal", color: "bg-blue-100" },
    { member: "Supply Chain Manager", task: "2.5 End-to-end procurement and contracting", dept: "Supply Chain Management (SCM)", color: "bg-sky-100" },

    { member: "Mechanical Engineer", task: "3.1 Conceptual CAD Models: Initial 3D designs", dept: "Engineering Department", color: "bg-green-100" },
    { member: "Mechanical Engineer", task: "3.2 Digital Analysis Report: Digital testing", dept: "Engineering Department", color: "bg-green-100" },
    { member: "Mechanical Engineer", task: "3.3 Prototype Verification", dept: "Engineering Department", color: "bg-green-100" },
    { member: "Senior Mechanical Engineer", task: "3.4 Final technical drawings", dept: "Engineering Department", color: "bg-blue-100" },

    { member: "Mechanical Engineer", task: "4.1 Testing Under Real-Life Conditions", dept: "Engineering Department", color: "bg-green-100" },
    { member: "Quality Assurance Engineer", task: "4.2 Monitoring Vandalism Of The New Product", dept: "Operations", color: "bg-purple-100" },

    { member: "Senior Mechanical Engineer", task: "5.1 Final Prototype Delivery", dept: "Engineering Department", color: "bg-blue-100" },
    { member: "Senior Mechanical Engineer", task: "5.2 Technical Documentation Package", dept: "Engineering Department", color: "bg-blue-100" },
    { member: "Project Manager", task: "5.3 Lessons Learned", dept: "Management", color: "bg-yellow-100" },
];
---

<MainLayout title="Responsibilities">
    <section class="space-y-10">
        <header class="max-w-4xl">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-indigo-600 mb-3">
                Planning
            </p>
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 mb-4">
                Responsibilities
            </h1>
            <p class="text-lg text-slate-600">
                Team member assignments for project execution. Colors correspond to the phase map in
                our Gantt chart schedule.
            </p>
        </header>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm overflow-x-auto">
            <table class="w-full border-collapse text-left text-sm">
                <thead>
                <tr class="bg-slate-50 text-slate-700">
                    <th class="px-4 py-3 border-b border-slate-200 font-semibold w-1/4">Team Member</th>
                    <th class="px-4 py-3 border-b border-slate-200 font-semibold w-1/2">Role and Task</th>
                    <th class="px-4 py-3 border-b border-slate-200 font-semibold w-1/4">Department</th>
                </tr>
                </thead>
                <tbody class="text-slate-800">
                {responsibilities.map((row) => (
                        <tr class={`${row.color} hover:opacity-80 transition-opacity`}>
                            <td class="px-4 py-3 border-b border-slate-200/50">{row.member}</td>
                            <td class="px-4 py-3 border-b border-slate-200/50">{row.task}</td>
                            <td class="px-4 py-3 border-b border-slate-200/50">{row.dept}</td>
                        </tr>
                ))}
                </tbody>
            </table>
        </div>
    </section>
</MainLayout>